# ──────────────────────────────────────────────
#  ClaraX .gitignore
#  Rust + Python (PyO3) project
# ──────────────────────────────────────────────

# ── Rust / Cargo ──────────────────────────────
target/
Cargo.lock
*.so
*.dylib
*.dll
*.pyd

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*.egg
*.egg-info/
dist/
build/
wheels/
pip-wheel-metadata/
*.whl

# ── Virtual environments ──────────────────────
.venv/
venv*/
.nox/
.tox/

# ── Testing & coverage ───────────────────────
.pytest_cache/
.hypothesis/
htmlcov/
lcov.info
coverage.json
coverage.xml
.coverage
*.gcda
*.gcno

# ── Type checking & linting ──────────────────
.mypy_cache/
.ruff_cache/
.cache/

# ── Secrets & environment ────────────────────
.env
.env.local
.env.*.local

# ── OS artifacts ─────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editors & IDEs ───────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Documentation build ─────────────────────
/doc/
/gh-pages/
guide/book/
guide/src/LICENSE-APACHE
guide/src/LICENSE-MIT
netlify_build/
.lycheecache
site/

# ── Misc ─────────────────────────────────────
.eggs/
extensions/stamps/
valgrind-python.supp
*.out
